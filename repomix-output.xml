  //           setMissedProbs(missesProbs + 1);
  //         } else {
  //           setTickShow(true);
  //           setHideTick(false);

  //           setCurrentScore(currentScore + 1);
  //           setCurrent(currentScore + 1);
  //         }
  //       }
  //       break;
  //     case 2:
  //       NextProb();
  //       break;
  //   }
  // }, [
  //   quizState,
