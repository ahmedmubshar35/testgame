  //   data.forEach((item: any, idx: number) => {
  //     preselectedOption.push(item.name);
  //     options.push({
  //       title: item.name,
  //       value: item._id,
  //       isCategory: true,
  //       isSelected: true,
  //       subCategories: item.subcategories.map(
  //         (subcategory: any, index: number) => ({
  //           title: subcategory,
  //           value: subcategory,
  //           isCategory: false,
  //           isSelected: idx == 0 && index == 0 ? true : true,
  //         })
  //       ),
  //     });
  //   });

  //   setCategories(options);
  //   setSelectedCategories(preselectedOption);
  // };
  const getAllCategories = async () => {
    try {
      let data = await getAllQuestionsCategories();
  
      if (data.success === false) {
        if (setCategoryState === 1) {
          Toast.show(
            "Your game is only available on paid accounts. Subscribe to your account",
            Toast.SHORT 
          );
          goToSetting();
          return; // Prevent further execution
        }
