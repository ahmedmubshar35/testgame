                <TouchableOpacity
                    style={styles.toggleButton}
                    onPress={() => setHidePassword(!hidePassword)}
                >
                    {hidePassword ? <HideIcon /> : <ShowIcon />} 
                </TouchableOpacity>
            </View>
        )
        case 'multiline': 
            return (
                <TextInput style={[styles.multiline, {height: height}]} 
                    value={initValue}
                    onChangeText={onChangeText}
                    multiline={true}
                />
            )
            break;
     }
}

